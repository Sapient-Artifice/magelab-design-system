{
  "shared": {
    "typography": {
      "font": {
        "sans": "Inter, \"Segoe UI\", sans-serif",
        "mono": "\"SFMono-Regular\", Consolas, \"Liberation Mono\", monospace",
        "accent": "Georgia, \"Times New Roman\", serif"
      },
      "size": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "md": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "2rem",
        "4xl": "clamp(2.75rem, 6vw, 4rem)"
      },
      "lineHeight": {
        "tight": "1.1",
        "snug": "1.25",
        "body": "1.7"
      },
      "letterSpacing": {
        "eyebrow": "0.15em",
        "tight": "-0.04em"
      }
    },
    "color": {
      "gray": {
        "50": "#fafafa",
        "100": "#f4f4f5",
        "200": "#e4e4e7",
        "300": "#d4d4d8",
        "400": "#a1a1aa",
        "500": "#71717a",
        "600": "#52525b",
        "700": "#3f3f46",
        "800": "#27272a",
        "900": "#18181b",
        "950": "#09090b"
      },
      "mage": {
        "50": "#f5f3ff",
        "100": "#ede9fe",
        "200": "#ddd6fe",
        "300": "#c4b5fd",
        "400": "#a78bfa",
        "500": "#8b5cf6",
        "600": "#7c3aed",
        "700": "#6d28d9",
        "800": "#5b21b6",
        "900": "#4c1d95"
      },
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#60a5fa"
    },
    "radius": {
      "sm": "0.375rem",
      "md": "0.5rem",
      "lg": "0.625rem",
      "xl": "0.875rem",
      "2xl": "1.125rem",
      "3xl": "1.375rem"
    },
    "space": {
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    },
    "layout": {
      "container": {
        "sm": "48rem",
        "md": "64rem",
        "lg": "72rem",
        "xl": "80rem"
      },
      "borderWidth": {
        "thin": "1px",
        "thick": "2px"
      }
    },
    "shadow": {
      "sm": "0 1px 2px rgba(0, 0, 0, 0.18)",
      "md": "0 12px 32px rgba(0, 0, 0, 0.24)",
      "lg": "0 20px 60px -15px rgba(0, 0, 0, 0.8)",
      "xl": "0 36px 120px -24px rgba(0, 0, 0, 0.9)",
      "glow": "0 0 32px 6px rgba(139, 92, 246, 0.3), 0 0 64px 8px rgba(139, 92, 246, 0.15)"
    },
    "motion": {
      "easeStandard": "ease",
      "easeEmphasized": "cubic-bezier(0.22, 1, 0.36, 1)",
      "durationFast": "160ms",
      "durationBase": "240ms",
      "durationSlow": "400ms"
    },
    "zIndex": {
      "base": 1,
      "sticky": 20,
      "dropdown": 30,
      "overlay": 40,
      "modal": 50
    }
  },
  "themes": {
    "dark": {
      "meta": {
        "colorScheme": "dark"
      },
      "color": {
        "background": "#09090b",
        "foreground": "#fafafa",
        "card": "#121217",
        "cardForeground": "{color.foreground}",
        "popover": "#121217",
        "popoverForeground": "#e4e4e7",
        "primary": "{color.mage.500}",
        "primaryForeground": "#fafafa",
        "secondary": "#18181b",
        "secondaryForeground": "#d4d4d8",
        "muted": "#18181b",
        "mutedForeground": "#a1a1aa",
        "accent": "rgba(255, 255, 255, 0.08)",
        "accentForeground": "#e4e4e7",
        "destructive": "#ef4444",
        "border": "rgba(255, 255, 255, 0.08)",
        "borderStrong": "rgba(255, 255, 255, 0.14)",
        "input": "rgba(255, 255, 255, 0.1)",
        "ring": "{color.mage.500}",
        "overlay": "rgba(0, 0, 0, 0.66)",
        "successSoft": "rgba(16, 185, 129, 0.16)",
        "warningSoft": "rgba(245, 158, 11, 0.16)",
        "errorSoft": "rgba(239, 68, 68, 0.16)"
      }
    },
    "light": {
      "meta": {
        "colorScheme": "light"
      },
      "color": {
        "background": "#fcfcfe",
        "foreground": "#14141b",
        "card": "#ffffff",
        "cardForeground": "#14141b",
        "popover": "#ffffff",
        "popoverForeground": "#14141b",
        "primary": "{color.mage.700}",
        "primaryForeground": "#ffffff",
        "secondary": "#f4f4f7",
        "secondaryForeground": "#2a2a33",
        "muted": "#f4f4f7",
        "mutedForeground": "#5b5b66",
        "accent": "rgba(109, 40, 217, 0.08)",
        "accentForeground": "#2a2a33",
        "destructive": "#dc2626",
        "border": "rgba(20, 20, 27, 0.12)",
        "borderStrong": "rgba(20, 20, 27, 0.2)",
        "input": "rgba(20, 20, 27, 0.12)",
        "ring": "{color.mage.600}",
        "overlay": "rgba(9, 9, 11, 0.28)",
        "successSoft": "rgba(16, 185, 129, 0.12)",
        "warningSoft": "rgba(245, 158, 11, 0.14)",
        "errorSoft": "rgba(239, 68, 68, 0.12)"
      }
    }
  }
}
