{
  "name": "@magelab/design-system",
  "version": "0.1.0",
  "description": "Framework-agnostic design tokens and CSS primitives for Magelab products.",
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "design-system",
    "css",
    "tokens",
    "magelab"
  ],
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "assets",
    "effects",
    "src",
    "tailwind",
    "tokens",
    "vendor/three.core.js",
    "vendor/three.module.js",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.css",
    "./assets/*": "./assets/*",
    "./assets/favicon.ico": "./assets/favicon.ico",
    "./assets/favicon.png": "./assets/favicon.png",
    "./assets/favicon-32x32.png": "./assets/favicon-32x32.png",
    "./assets/favicon-16x16.png": "./assets/favicon-16x16.png",
    "./assets/brand-mark.svg": "./assets/brand-mark.svg",
    "./index.css": "./src/index.css",
    "./tokens.css": "./src/tokens.css",
    "./base.css": "./src/base.css",
    "./utilities.css": "./src/utilities.css",
    "./effects.css": "./src/effects.css",
    "./effects": "./effects/index.js",
    "./tailwind/theme.css": "./tailwind/theme.css",
    "./tailwind/preset": "./tailwind/preset.js",
    "./tokens.json": "./src/tokens.json",
    "./tokens.source.json": "./tokens/tokens.source.json",
    "./vendor/three.core.js": "./vendor/three.core.js",
    "./vendor/three.module.js": "./vendor/three.module.js"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:catalog": "node scripts/build-catalog.mjs",
    "check": "node scripts/check-exports.mjs",
    "validate": "npm run build:tokens && npm run check && npm run build:catalog",
    "test": "npm run check",
    "release:check": "npm run build:tokens && npm run check && npm run build:catalog && npm pack --dry-run --cache ./.npm-cache",
    "dev": "node scripts/serve-static.mjs . 4173",
    "dev:tailwind-demo": "node scripts/serve-static.mjs . 4175",
    "preview": "node scripts/serve-static.mjs dist 4174"
  }
}
